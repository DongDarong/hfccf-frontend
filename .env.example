# Backend API base URL.
# Local dev:   http://hfccf-backend.test/api
# Production:  https://api.hfccf.org  (full HTTPS URL of the backend)
VITE_API_BASE_URL=http://hfccf-backend.test/api

# Trusted public image origin for CSP and avatar rendering.
# Use either the exact origin or the full public URL; the app resolves the origin automatically.
VITE_IMAGE_PUBLIC_ORIGIN=
VITE_IMAGE_PUBLIC_URL=
